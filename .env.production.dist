# Production — скопировать в .env на VPS

# Docker: при нескольких проектах — уникальные порты (другой проект уже занял 80)
COMPOSE_PROJECT_NAME=hd_realty
NGINX_HTTP_PORT=8080

DJANGO_SETTINGS_MODULE=core.settings.production
DEBUG=False
SECRET_KEY=сгенерировать-длинный-секретный-ключ
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost,45.138.159.251

# CSRF: домены, с которых приходят запросы (admin, API через браузер)
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,http://yourdomain.com,https://45.138.159.251:8080,http://45.138.159.251:8080

# CORS: домены фронтенда (SPA), которые обращаются к API
CORS_ALLOWED_ORIGINS=https://yourdomain.com,http://yourdomain.com,https://45.138.159.251:8080,http://45.138.159.251:8080

# БД (PostgreSQL в Docker)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=hd_realty
DB_USER=postgres
DB_PASSWORD=надежный-пароль

# Хост БД — имя сервиса в docker-compose
DB_HOST=db
DB_PORT=5432

# DB_OPTIONS для облачной PostgreSQL (раскомментировать при необходимости)
# DB_OPTIONS={"sslmode":"require"}
